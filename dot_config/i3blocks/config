separator=true
separator_block_width=15

[time]
command=date '+%Y-%m-%d %H:%M:%S'
interval=1

[split_mode]
command=cat /tmp/i3_split_mode 2>/dev/null || echo "H"
interval=once
signal=10

[mediaplayer]
command=~/.config/i3/scripts/mediaplayer.sh
instance=playerctl
interval=5
signal=10
color=#f3f4f5

[volume]
command=~/.config/i3/scripts/volume.sh
label=VOL 
interval=5
signal=10
